{
  "name": "goldencheck",
  "version": "0.1.0",
  "description": "Data validation that discovers rules from your data. TypeScript port of the goldencheck Python library.",
  "keywords": [
    "data-validation",
    "data-quality",
    "profiling",
    "csv",
    "goldencheck",
    "drift-detection",
    "schema",
    "edge"
  ],
  "license": "MIT",
  "author": "Ben Severn (https://bensevern.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/benzsevern/goldencheck.git",
    "directory": "packages/goldencheck-js"
  },
  "homepage": "https://benzsevern.github.io/goldencheck/",
  "bugs": {
    "url": "https://github.com/benzsevern/goldencheck/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js",
      "require": "./dist/node/index.cjs"
    }
  },
  "bin": {
    "goldencheck-js": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "peerDependencies": {
    "nodejs-polars": "*",
    "yaml": "*"
  },
  "peerDependenciesMeta": {
    "nodejs-polars": { "optional": true },
    "yaml": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nodejs-polars": "^0.24.1",
    "rimraf": "^5.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0",
    "yaml": "^2.7.0"
  }
}
